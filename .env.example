# Copy this file to .env and fill in real values. Never commit the real .env.

# --- Core Django ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# "True"/"False". Must be "False" in production.
DEBUG=False

# "True" to read individual DB_* vars below, "False" to use DATABASE_URL instead.
DEVELOPMENT_MODE=False

# Comma-separated, no spaces. e.g. bims.yourcompany.com,203.0.113.10
ALLOWED_HOSTS=

# Comma-separated full origins (with scheme), required for CSRF behind HTTPS.
# e.g. https://bims.yourcompany.com
CSRF_TRUSTED_ORIGINS=

# "True"/"False". Leave unset in production to auto-enable when DEBUG=False.
# Useful to explicitly set "False" right after a fresh deploy, before TLS is live.
SECURE_SSL_REDIRECT=

# IANA timezone name, e.g. Asia/Kolkata
TIME_ZONE=UTC

# --- Database (used when DEVELOPMENT_MODE=True) ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60
DB_CONNECT_TIMEOUT=10

# --- Database (used when DEVELOPMENT_MODE=False) ---
# postgres://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=

# --- Redis (Celery broker + Django cache, separate logical DBs) ---
REDIS_URL=redis://localhost:6379/0
REDIS_CACHE_URL=redis://localhost:6379/1

# --- Session ---
SESSION_COOKIE_AGE=28800
SESSION_EXPIRE_AT_BROWSER_CLOSE=True

# --- HSTS (only used when DEBUG=False) ---
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# --- Email ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
