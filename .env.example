# Copy this file to .env and fill in real values. Never commit the real .env.

# --- Core Django ---
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=

# "True"/"False". Must be "False" in production.
DEBUG=False

# "True" to read individual DB_* vars below, "False" to use DATABASE_URL instead.
DEVELOPMENT_MODE=False

# Comma-separated, no spaces. e.g. bims.yourcompany.com,203.0.113.10
ALLOWED_HOSTS=

# Comma-separated full origins (with scheme), required for CSRF behind HTTPS.
# e.g. https://bims.yourcompany.com
CSRF_TRUSTED_ORIGINS=

# "True"/"False". Leave unset in production to auto-enable when DEBUG=False.
# Useful to explicitly set "False" right after a fresh deploy, before TLS is live.
SECURE_SSL_REDIRECT=

# IANA timezone name, e.g. Asia/Kolkata
TIME_ZONE=UTC

# --- Database (used when DEVELOPMENT_MODE=True) ---
DB_ENGINE=django.db.backends.postgresql
DB_NAME=
DB_USER=
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_CONN_MAX_AGE=60
DB_CONNECT_TIMEOUT=10

# --- Database (used when DEVELOPMENT_MODE=False) ---
# postgres://USER:PASSWORD@HOST:PORT/DBNAME
# On DigitalOcean App Platform, this is usually auto-injected when you attach
# a database component (bindable as ${db.DATABASE_URL} in the app spec) -
# you don't need to copy/paste it by hand in that case.
DATABASE_URL=

# "require" is correct for DigitalOcean Managed/Dev Databases, which reject
# non-SSL connections. Only override if DATABASE_URL already carries its own
# ?sslmode=... (that takes precedence) or you're connecting to a DB without SSL.
DB_SSLMODE=require

# --- Session ---
SESSION_COOKIE_AGE=28800
SESSION_EXPIRE_AT_BROWSER_CLOSE=True

# --- HSTS (only used when DEBUG=False) ---
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# --- Email ---
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# --- SMS (SMSGatewayHub) ---
# Master switch. "False" (default) means no SMS is sent anywhere.
SMS_ENABLED=True

# "True" routes sends to an in-memory mock provider (no network, no cost).
# Leave unset to auto-enable in local development (DEBUG=True). Force "False"
# in production once real credentials are configured.
SMS_MOCK=False

# Provider selector. Currently "smsgatewayhub"; add others without code changes
# to callers by registering a provider in notification/services/sms_service.py.
SMS_PROVIDER=smsgatewayhub

# Network timeout (seconds) and transient-failure retry policy.
SMS_TIMEOUT=10
SMS_MAX_RETRIES=2
SMS_RETRY_BACKOFF=0.5

# Country code prepended to bare national numbers (e.g. 91 for India).
SMS_DEFAULT_COUNTRY_CODE=91

# Hard cap on message length (characters).
SMS_MAX_LENGTH=1000

# SMSGatewayHub account credentials and routing. Keep these secret.
SMS_GATEWAYHUB_BASE_URL=https://www.smsgatewayhub.com
SMS_GATEWAYHUB_API_KEY=5pvGZ0sHkUis0D88uHDNBA
SMS_GATEWAYHUB_SENDER_ID=HTFARM
SMS_GATEWAYHUB_ROUTE=1
SMS_GATEWAYHUB_CHANNEL=2
SMS_GATEWAYHUB_DCS=0

# DLT fields (mandatory for Indian transactional traffic when provisioned).
SMS_GATEWAYHUB_ENTITY_ID=1301160705981331943
SMS_GATEWAYHUB_DLT_TEMPLATE_ID=

# --- Environmental Monitoring (Tapo H100 / T310) ---
# Tapo account email/password are NOT set here - they're a DB-backed master
# record, editable from the ERP UI at Environmental Monitoring > Tapo Account.

# How often `python manage.py poll_sensors` should be scheduled to run
# (seconds) - configure this cadence in Windows Task Scheduler/cron, this
# value is only used to compute e.g. offline detection windows.
ENV_MONITORING_POLL_INTERVAL_SECONDS=60

# Minutes without a successful reading before a hub/sensor is flagged offline.
ENV_MONITORING_OFFLINE_AFTER_MINUTES=15

# Default alert thresholds are NOT set here - they're a DB-backed master
# record, editable from the ERP UI at Environmental Monitoring > Default
# Thresholds (overridable further per-sensor).
